POSTGRES_DB=door010
POSTGRES_USER=door010
POSTGRES_PASSWORD=replace-with-a-long-random-password
AUTH_TOKEN_SECRET=replace-with-at-least-32-random-characters
DOOR010_API_PORT=4000
DOOR010_IMAGE_TAG=local
METRICS_TOKEN=replace-with-a-long-random-monitoring-token
PROMETHEUS_PORT=9090
LOG_LEVEL=info
DOOR010_WEB_PORT=8080

# OpenAI-compatible LLM endpoint
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=replace-with-provider-key
LLM_MODEL=replace-with-model
LLM_TIMEOUT_MS=30000

# JSON vacancy and event providers
VACANCY_API_URL=https://provider.example.com/vacancies
VACANCY_API_KEY=replace-with-provider-key
EVENT_API_URL=https://provider.example.com/events
EVENT_API_NAME=Door010 event provider
EVENT_API_KEY=replace-with-provider-key

# Provider-neutral notification webhook
NOTIFICATION_WEBHOOK_URL=https://provider.example.com/notifications
NOTIFICATION_WEBHOOK_TOKEN=replace-with-provider-token

# Provider resilience defaults
PROVIDER_MAX_ATTEMPTS=3
PROVIDER_INITIAL_DELAY_MS=250
PROVIDER_FAILURE_THRESHOLD=5
PROVIDER_RESET_TIMEOUT_MS=30000


# API security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_DEFAULT=180
RATE_LIMIT_AUTH=20
DEAD_LETTER_RETENTION_DAYS=30
DEAD_LETTER_STORE_BODY=false


# Adaptive trusted-source web retrieval
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev/v1/search

# Optional OpenAI-compatible embeddings
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1536
EMBEDDING_TIMEOUT_MS=30000


# Optional provider-independent cross-encoder shadow mode
CROSS_ENCODER_ENDPOINT=
CROSS_ENCODER_API_KEY=
CROSS_ENCODER_MODEL=
CROSS_ENCODER_TIMEOUT_MS=20000

# Active learning
ACTIVE_LEARNING_MARGIN_THRESHOLD=0.12


# Domain knowledge connectors
EDUCATION_CONNECTOR_URL=
SUBSIDY_CONNECTOR_URL=
EVENT_CONNECTOR_URL=
VACANCY_CONNECTOR_URL=

# Optional environment variable name containing an Authorization header.
# Example: CONNECTOR_AUTHORIZATION_SECRET=DOMAIN_CONNECTOR_TOKEN
CONNECTOR_AUTHORIZATION_SECRET=
DOMAIN_CONNECTOR_TOKEN=

# Distributed connector scheduler
CONNECTOR_SCHEDULER_OWNER_ID=
CONNECTOR_LEASE_DURATION_MS=300000

# Optional model-assisted planner in shadow mode
PLANNER_SHADOW_ENDPOINT=
PLANNER_SHADOW_API_KEY=
PLANNER_SHADOW_MODEL=
PLANNER_SHADOW_TIMEOUT_MS=10000

# Notification delivery worker
NOTIFICATION_WORKER_INTERVAL_MS=30000
NOTIFICATION_DELIVERY_TIMEOUT_MS=10000

# Optional external delivery providers
EMAIL_DELIVERY_ENDPOINT=
EMAIL_DELIVERY_API_KEY=
WEBHOOK_DELIVERY_ENDPOINT=
WEBHOOK_DELIVERY_API_KEY=
